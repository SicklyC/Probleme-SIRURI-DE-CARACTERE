#include <bits/stdc++.h>
using namespace std;
char v[256];
int a,p;
int main()
{
    cin.getline(v,256);
    a=strlen(v);
    p=0;
    for(int i=0;i<a-1;i++){
    if((v[i] == 'a' || v[i] == 'e' || v[i] == 'i' || v[i] == 'o'|| v[i] == 'u')&&(v[i+1] == 'a' || v[i+1] == 'e' || v[i+1] == 'i' || v[i+1] == 'o'|| v[i+1] == 'u'))
            p++;
        }
    cout<<p;
}
