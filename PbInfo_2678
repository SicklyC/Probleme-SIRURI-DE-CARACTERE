#include <bits/stdc++.h>
using namespace std;
char m[256],c;
int a,nr,total;
int main()
{
   cin.getline(m,256);
   a=strlen(m);
   for(int i=0;i<a;i++){
    c=m[i];
    if(c>='0'&&c<='9'){
        nr=nr*10+(c-'0');
    }else{
        total+=nr;
        nr=0;
    }
   }
    cout << total;
    return 0;
}
