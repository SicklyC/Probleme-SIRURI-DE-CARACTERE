#include <bits/stdc++.h>
using namespace std;
ifstream f("palindrom.in");
ofstream g("palindrom.out");
char m[256],c;
bool ok;
int a,b;
int main()
{
    f>>a;
    f.get();
    for(int j=0; j<a; j++)
    {
        f.getline(m,256);
        ok=true;
        b=strlen(m);
        for(int i=0; i<b/2; i++)
        {
            if(m[i]!=m[b-1-i])
            {
                ok=false;
            }
        }
        if(ok)
        {
            g<<1<<"\n";
        }
        else
        {
            g<<0<<"\n";
        }
    }
}
