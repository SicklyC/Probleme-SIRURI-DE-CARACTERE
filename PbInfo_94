#include <bits/stdc++.h>
using namespace std;
char v[21];
int a;
int main()
{
    cin.getline(v,21);
    a=strlen(v);
    for(int i=0;i<a;i++){
    if(v[i] == 'a' || v[i] == 'e' || v[i] == 'i' || v[i] == 'o'|| v[i] == 'u')
            {
                for(int j=i; j<a; j++)
                    v[j]=v[j+1];
                a--;
                i--;
            }
        }
    cout<<v;
}
